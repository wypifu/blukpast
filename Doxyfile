#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "Blukpast"
PROJECT_BRIEF          = "Lightweight Vulkan graphics library in C"
PROJECT_NUMBER         = "0.6.0"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                  = . README.md
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = YES
EXCLUDE                = thirdparty
EXCLUDE_PATTERNS       = */thirdparty/* \
                         */test/*
EXTENSION_MAPPING      = h=C c=C

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#---------------------------------------------------------------------------
# C specifics
#---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES

# Expand BKP_EXPORTED so Doxygen sees plain function signatures
PREDEFINED             = BKP_EXPORTED= \
                         BKP_TRUE=1 \
                         BKP_FALSE=0

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# doxygen-awesome theme
# Clone first: git clone https://github.com/jothepro/doxygen-awesome-css docs/doxygen-awesome-css
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome-css/doxygen-awesome.css \
                         docs/doxygen-awesome-css/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = docs/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         docs/doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         docs/doxygen-awesome-css/doxygen-awesome-paragraph-link.js
HTML_HEADER            = docs/header.html
HTML_COLORSTYLE        = LIGHT

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_INDEX_NUM_ENTRIES = 100
SHOW_NAMESPACES        = NO
ALPHABETICAL_INDEX     = YES

#---------------------------------------------------------------------------
# Diagrams (requires graphviz)
#---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = NO
CLASS_GRAPH            = YES

#---------------------------------------------------------------------------
# Other outputs (disabled)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Search
#---------------------------------------------------------------------------
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
